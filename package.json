{
  "name": "open-basket",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.3.1",
      "zod": "^4.3.6",
      "typescript": "^5.9.3",
      "@types/node": "^25.4.0",
      "@libsql/client": "^0.17.0",
      "libsql": "0.5.22",
      "@paralleldrive/cuid2": "^2.2.2"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:native": "turbo -F native dev",
    "dev:web": "turbo -F web dev",
    "db:push": "turbo -F @open-basket/db db:push",
    "db:studio": "turbo -F @open-basket/db db:studio",
    "db:generate": "turbo -F @open-basket/db db:generate",
    "db:migrate": "turbo -F @open-basket/db db:migrate",
    "db:local": "turbo -F @open-basket/db db:local",
    "check": "ultracite check",
    "fix": "ultracite fix"
  },
  "dependencies": {
    "@open-basket/env": "workspace:*",
    "dotenv": "catalog:",
    "framer-motion": "^12.35.2",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.5",
    "@open-basket/config": "workspace:*",
    "@types/node": "catalog:",
    "turbo": "^2.8.16",
    "typescript": "catalog:",
    "ultracite": "7.2.5"
  },
  "packageManager": "bun@1.3.10"
}
